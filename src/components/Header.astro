---
import { GITHUB_URL, SITE_AUTHOR } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
	{ href: "/", label: "Home" },
	{ href: "/notes", label: "Knowledge" },
	{ href: "/blog", label: "Blog" },
	{ href: "/projects", label: "Projects" },
	{ href: "/about", label: "About" },
];
---

<header class="site-header">
	<nav class="site-nav" aria-label="Primary navigation">
		<a class="logo" href="/" aria-label={`${SITE_AUTHOR} home`}>
			<span aria-hidden="true">M</span>
			<strong>{SITE_AUTHOR}</strong>
		</a>

		<div class="nav-links">
			{navItems.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
		</div>

		<div class="header-actions">
			{
				GITHUB_URL && (
					<a class="github-link" href={GITHUB_URL} target="_blank" rel="noreferrer">
						GitHub
					</a>
				)
			}
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(var(--color-border), 0.9);
		background: rgba(var(--color-fill), 0.86);
		backdrop-filter: blur(16px);
	}

	.site-nav {
		display: grid;
		grid-template-columns: auto 1fr auto;
		gap: 1.5rem;
		align-items: center;
		width: min(100% - 2rem, 72rem);
		min-height: 4rem;
		margin: 0 auto;
	}

	.logo {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		color: rgb(var(--color-text-base));
		font-size: 0.98rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
	}

	.logo span {
		display: grid;
		place-items: center;
		width: 2rem;
		height: 2rem;
		border: 1px solid rgba(var(--color-border), 0.9);
		border-radius: 6px;
		background: rgba(var(--color-card), 0.35);
		color: rgb(var(--color-accent));
		font-size: 0.92rem;
	}

	.logo:hover,
	.logo:focus-visible {
		color: rgb(var(--color-text-base));
	}

	.nav-links {
		display: flex;
		justify-content: center;
		gap: 0.25rem;
	}

	.nav-links :global(a),
	.github-link {
		display: inline-flex;
		align-items: center;
		min-height: 2.25rem;
		padding: 0.45rem 0.65rem;
		border-radius: 6px;
		color: rgba(var(--color-text-base), 0.72);
		font-size: 0.92rem;
		font-weight: 650;
		line-height: 1;
		text-decoration: none;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a:focus-visible),
	.github-link:hover,
	.github-link:focus-visible {
		background: rgba(var(--color-card), 0.45);
		color: rgb(var(--color-text-base));
	}

	.nav-links :global(a.active) {
		background: rgba(var(--color-card), 0.55);
		color: rgb(var(--color-text-base));
	}

	.github-link {
		justify-self: end;
		border: 1px solid rgba(var(--color-border), 0.9);
	}

	.header-actions {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.5rem;
	}

	@media (max-width: 760px) {
		.site-nav {
			grid-template-columns: 1fr auto;
			row-gap: 0.75rem;
			min-height: auto;
			padding: 0.75rem 0;
		}

		.nav-links {
			grid-column: 1 / -1;
			justify-content: flex-start;
			overflow-x: auto;
			padding-bottom: 0.15rem;
			scrollbar-width: none;
		}

		.header-actions {
			grid-column: 2;
			grid-row: 1;
		}

		.nav-links::-webkit-scrollbar {
			display: none;
		}
	}
</style>
