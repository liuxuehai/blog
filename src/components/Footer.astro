---
import { GITHUB_URL, SITE_AUTHOR } from "../consts";

const footerLinks = [
	{ href: "/notes", label: "Knowledge" },
	{ href: "/blog", label: "Blog" },
	{ href: "/projects", label: "Projects" },
	{ href: "/changelog", label: "Changelog" },
	...(GITHUB_URL ? [{ href: GITHUB_URL, label: "GitHub", external: true }] : []),
	{ href: "/rss.xml", label: "RSS" },
];
---

<footer class="site-footer">
	<div class="footer-inner">
		<a class="footer-brand" href="/">{SITE_AUTHOR}</a>
		<nav class="footer-links" aria-label="Footer navigation">
			{
				footerLinks.map((link) => (
					<a
						href={link.href}
						target={link.external ? "_blank" : undefined}
						rel={link.external ? "noreferrer" : undefined}
					>
						{link.label}
					</a>
				))
			}
		</nav>
		<p>Built with Astro</p>
	</div>
</footer>

<style>
	.site-footer {
		border-top: 1px solid rgba(var(--color-border), 0.9);
		background: rgba(var(--color-card), 0.18);
	}

	.footer-inner {
		display: grid;
		gap: 1rem;
		width: min(100% - 2rem, 72rem);
		margin: 0 auto;
		padding: 2rem 0;
	}

	.footer-brand {
		width: fit-content;
		color: rgb(var(--color-text-base));
		font-size: 1rem;
		font-weight: 800;
		line-height: 1;
		text-decoration: none;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1rem;
	}

	.footer-links a {
		color: rgba(var(--color-text-base), 0.7);
		font-size: 0.92rem;
		font-weight: 650;
		text-decoration: none;
	}

	.footer-links a:hover,
	.footer-links a:focus-visible {
		color: rgb(var(--color-accent));
	}

	p {
		margin: 0;
		color: rgba(var(--color-text-base), 0.58);
		font-size: 0.88rem;
		line-height: 1.5;
	}
</style>
