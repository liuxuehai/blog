---
type Props = {
	titleId?: string;
	eyebrow?: string;
	title: string;
	description?: string;
};

const { titleId, eyebrow, title, description } = Astro.props;
---

<div class="section-title">
	{eyebrow && <p>{eyebrow}</p>}
	<h2 id={titleId}>{title}</h2>
	{description && <span>{description}</span>}
</div>

<style>
	.section-title {
		display: grid;
		grid-template-columns: minmax(12rem, 0.65fr) minmax(16rem, 1fr);
		gap: 2rem;
		align-items: end;
		width: 100%;
		margin-bottom: 2rem;
	}

	p {
		grid-column: 1 / -1;
		margin: 0 0 -1.35rem;
		color: rgb(var(--color-accent));
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0;
		line-height: 1.2;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
		font-size: 2.35rem;
		font-weight: 600;
		letter-spacing: 0;
	}

	span {
		display: block;
		margin: 0;
		color: rgba(var(--color-text-base), 0.68);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	@media (max-width: 620px) {
		.section-title {
			grid-template-columns: 1fr;
			gap: 0.65rem;
		}

		p {
			grid-column: auto;
			margin: 0 0 0.15rem;
		}
	}
</style>
