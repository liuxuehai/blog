---
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import PostCard from "../../components/PostCard.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
	getCategoryLabel,
	getCategorySlug,
	getGroupedPostsByCategory,
	getPostsByCategory,
} from "../../lib/content";

export async function getStaticPaths() {
	const groupedPosts = await getGroupedPostsByCategory();

	return Object.keys(groupedPosts).map((category) => ({
		params: { slug: getCategorySlug(category) },
		props: {
			category,
		},
	}));
}

const { category } = Astro.props;
const resolvedCategory = category;
const pageTitle = `${getCategoryLabel(resolvedCategory)} | ${SITE_TITLE}`;
const posts = await getPostsByCategory(resolvedCategory);
---

<BaseLayout title={pageTitle} description={SITE_DESCRIPTION}>
	<section>
		<SectionTitle
			eyebrow="Category"
			title={getCategoryLabel(resolvedCategory)}
			description={`共 ${posts.length} 篇文章。`}
		/>
		<div class="post-list">
			{posts.map((post) => <PostCard post={post} headingLevel="h2" />)}
		</div>
		{posts.length === 0 && <p>No posts found in this category.</p>}
	</section>
</BaseLayout>

<style>
	.post-list {
		display: grid;
	}
</style>
