---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<BaseLayout title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} mainClass="narrow">
	<section class="about">
		<p class="eyebrow">About</p>
		<h1>{SITE_AUTHOR}</h1>
		<p class="lead">分享技术、记录思考、构建项目。</p>

		<div class="content">
			<p>
				这个网站用于沉淀个人技术笔记、博客文章和项目记录。当前重点关注 Astro、
				Cloudflare、AI、Frontend、Backend、Database、DevOps 和 Linux。
			</p>
			<p>
				这里的内容会优先保持可维护：Blog 用来记录阶段性的实践和复盘，Knowledge
				用来整理可以持续更新的技术笔记。
			</p>
		</div>
	</section>
</BaseLayout>

<style>
	.about {
		padding: 1rem 0 3rem;
	}

	.eyebrow {
		margin: 0 0 0.85rem;
		color: rgb(var(--color-accent));
		font-size: 0.85rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		line-height: 1.2;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.4rem, 8vw, 4rem);
		letter-spacing: 0;
	}

	.lead {
		margin: 1rem 0 0;
		color: rgba(var(--color-text-base), 0.72);
		font-size: 1.2rem;
		line-height: 1.65;
	}

	.content {
		display: grid;
		gap: 1rem;
		margin-top: 2rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(var(--color-border), 0.9);
	}

	.content p {
		margin: 0;
		color: rgba(var(--color-text-base), 0.72);
		line-height: 1.8;
	}
</style>
