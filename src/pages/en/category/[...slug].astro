---
import PostCard from "../../../components/PostCard.astro";
import SectionTitle from "../../../components/SectionTitle.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations } from "../../../lib/i18n";
import {
	getCategoryLabel,
	getCategorySlug,
	getGroupedPostsByCategory,
	getPostsByCategory,
} from "../../../lib/content";

const { t } = useTranslations(Astro);

export async function getStaticPaths() {
	const groupedPosts = await getGroupedPostsByCategory();

	return Object.keys(groupedPosts).map((category) => ({
		params: { slug: getCategorySlug(category) },
		props: {
			category,
		},
	}));
}

const { category } = Astro.props;
const resolvedCategory = category;
const pageTitle = `${getCategoryLabel(resolvedCategory, 'en')} | ${t('site.title')}`;
const posts = await getPostsByCategory(resolvedCategory);
---

<BaseLayout title={pageTitle} description={t('site.description')}>
	<section>
		<SectionTitle
			eyebrow="Category"
			title={getCategoryLabel(resolvedCategory, 'en')}
			description={`${posts.length} posts found.`}
			headingLevel="h1"
		/>
		<div class="post-list">
			{posts.map((post) => <PostCard post={post} headingLevel="h2" />)}
		</div>
		{posts.length === 0 && <p>{t('blog.noPosts')}</p>}
	</section>
</BaseLayout>

<style>
	.post-list {
		display: grid;
	}
</style>
