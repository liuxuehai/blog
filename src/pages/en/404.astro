---
import { ArrowLeft, BookOpen } from "lucide-astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../lib/i18n";

const { t, getLocaleUrl } = useTranslations(Astro);
---

<BaseLayout
	title={`${t('common.notFound')} | ${t('site.title')}`}
	description={t('common.notFoundDescription')}
	mainClass="narrow"
>
	<section class="not-found">
		<p class="code">404</p>
		<h1>{t('common.notFound')}</h1>
		<p class="description">
			{t('common.notFoundDescription')}
		</p>
		<nav aria-label="404 page navigation">
			<a href={getLocaleUrl("/")}>
				<ArrowLeft size={17} strokeWidth={1.8} aria-hidden="true" />
				{t('common.goHome')}
			</a>
			<a href={getLocaleUrl("/notes/")}>
				<BookOpen size={17} strokeWidth={1.8} aria-hidden="true" />
				{t('knowledge.exploreNotes')}
			</a>
		</nav>
	</section>
</BaseLayout>

<style>
	.not-found {
		padding: 4rem 0 7rem;
	}

	.code {
		margin: 0 0 1rem;
		color: rgb(var(--color-accent));
		font-size: 0.82rem;
		font-weight: 800;
		line-height: 1;
	}

	h1 {
		max-width: 38rem;
		margin: 0;
		font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
		font-size: clamp(2.8rem, 8vw, 5.5rem);
		font-weight: 600;
		line-height: 1;
		letter-spacing: 0;
	}

	.description {
		max-width: 34rem;
		margin: 1.5rem 0 0;
		color: rgba(var(--color-text-base), 0.66);
		font-size: 1.05rem;
		line-height: 1.75;
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 2rem;
	}

	a {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.65rem 0.85rem;
		border: 1px solid rgba(var(--color-border), 0.95);
		border-radius: 4px;
		color: rgb(var(--color-text-base));
		font-size: 0.82rem;
		font-weight: 750;
		text-decoration: none;
	}

	a:hover {
		border-color: rgba(var(--color-accent), 0.55);
		background: rgba(var(--color-card), 0.35);
	}

	@media (max-width: 680px) {
		.not-found {
			padding: 2rem 0 5rem;
		}
	}
</style>
